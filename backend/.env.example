# 根目录 .env 配置 Docker Compose；本文件配置 FastAPI，二者用途不同且都不提交。
# Docker 使用时，此处密码必须与根目录 .env 的 MYSQL_PASSWORD 相同。
# 密码中的 @、:、/、?、# 等特殊字符必须在 DATABASE_URL 中进行 URL 编码。
DATABASE_URL=mysql+pymysql://ai_coach:replace_with_url_encoded_password@127.0.0.1:3307/ai_learning?charset=utf8mb4
AI_PROVIDER=deepseek
AI_API_KEY=你的_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# RAG / vector store
CHROMA_PERSIST_DIR=backend/chroma_db
CHROMA_COLLECTION=course_document_chunks_bge_small_zh_v15
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RAG_DEVICE=auto

# Other OpenAI-compatible examples:
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
