# 请先单独启动 MySQL/MariaDB。后端启动脚本不会自动启动或管理数据库。
# Docker 示例可使用 ai_coach:your_password；请在部署前修改默认密码。Docker 默认映射宿主机 3307 端口。
DATABASE_URL=mysql+pymysql://ai_coach:your_password@127.0.0.1:3306/ai_learning?charset=utf8mb4
AI_PROVIDER=deepseek
AI_API_KEY=你的_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# RAG / vector store
CHROMA_PERSIST_DIR=backend/chroma_db
CHROMA_COLLECTION=course_document_chunks_bge_small_zh_v15
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RAG_DEVICE=auto

# Other OpenAI-compatible examples:
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
